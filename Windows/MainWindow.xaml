<Window x:Class="Griddler_Solver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Griddler_Solver"
        mc:Ignorable="d"
        Title="Nonogram solver" Width="1024" Height="780" Icon="/app.ico" Closing="OnWindow_Closing">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="Auto" />
    </Grid.ColumnDefinitions>

    <!-- URL bar -->
    <Grid Grid.Row="0" Grid.ColumnSpan="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Label Grid.Column="0" Content="Url:" Margin="4"/>
      <ComboBox x:Name="comboBoxUrl" Grid.Column="1" Margin="4" IsEditable="True" SelectedIndex="0" MinHeight="26" VerticalAlignment="Center" VerticalContentAlignment="Center" SelectionChanged="OnComboBoxUrl_SelectionChanged"/>
    </Grid>

    <!-- Board canvas -->
    <Grid Grid.Row="1" Grid.Column="0">
      <local:BoardCanvas x:Name="boardCanvas" ClipToBounds="True" SizeChanged="OnCanvas_SizeChanged" MouseMove="OnCanvas_MouseMove"/>
    </Grid>

    <!-- Options panel -->
    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical">
      <Button Margin="4" MinHeight="26" MinWidth="100" Click="OnButtonDownload_Click" Content="Download"/>
      <Button Margin="4" MinHeight="26" MinWidth="100" Click="OnButtonSave_Click" Content="Save"/>
      <Button Margin="4" MinHeight="26" MinWidth="100" Click="OnButtonLoad_Click" Content="Load"/>
      <Separator Margin="4"/>
      <Button x:Name="buttonClearBoard" Margin="4" MinHeight="26" Click="OnButtonClearBoard_Click" Content="Clear board"/>
      <Button x:Name="buttonSolve" Margin="4" MinHeight="26" Click="OnButtonSolve_Click" Content="Solve"/>
      <Separator Margin="4"/>
      <Label x:Name="labelCoordinates" Margin="0 8 0 0" MinWidth="130" Padding="4 0" VerticalAlignment="Center"/>
    </StackPanel>
  </Grid>
</Window>
